#!/usr/bin/env raku

use v6.d;

use Blogin;
use Blogin::Log;
use Blogin::Config;
use Blogin::Scaffold;

my %*SUB-MAIN-OPTS = :named-anywhere;

sub make-log(Bool :$verbose, Bool :$quiet --> Blogin::Log) {
  my $level = do {
    if    $verbose { 'verbose' }
    elsif $quiet   { 'quiet' }
    else           { 'normal' }
  };

  Blogin::Log.new(:$level);
}

sub not-implemented(Str $name, Bool :$verbose, Bool :$quiet) {
  my $log = make-log(:$verbose, :$quiet);

  $log.error("$name is not implemented yet");

  exit 1;
}

multi sub MAIN(
  'build',
  Str  :$src = 'content',
  Str  :$out,
  Bool :$drafts = False,
  Int  :$jobs,
  Bool :$debug,
  Bool :$verbose = False,
  Bool :$quiet = False,
) {
  my $log    = make-log(:$verbose, :$quiet);
  my $config = Blogin::Config.load($src.IO.parent.add('blogin.json'));

  my %overrides;
  %overrides<out>   = $out.IO if $out.defined;
  %overrides<debug> = $debug  if $debug.defined;

  Blogin::build(
    :src($src.IO),
    :$config,
    :$drafts,
    jobs => ($jobs // ($*KERNEL.cpu-cores // 1)),
    :$log,
    |%overrides,
  );

  $log.info('build complete');
}

multi sub MAIN(
  'init',
  Str  $dir = '.',
  Str  :$framework = 'none',
  Bool :$force = False,
  Bool :$verbose = False,
  Bool :$quiet = False,
) {
  my $log = make-log(:$verbose, :$quiet);

  Blogin::Scaffold::init($dir.IO, :$framework, :$force);

  $log.info("scaffolded a Blogin site in $dir");
}

multi sub MAIN(
  'new',
  Str  $title,
  Str  :$section,
  Bool :$verbose = False,
  Bool :$quiet = False,
) {
  not-implemented('new', :$verbose, :$quiet);
}

multi sub MAIN(
  'serve',
  Str  :$src = 'content',
  Int  :$port = 3000,
  Bool :$verbose = False,
  Bool :$quiet = False,
) {
  require Blogin::Server <&serve>;

  my $log    = make-log(:$verbose, :$quiet);
  my $config = Blogin::Config.load($src.IO.parent.add('blogin.json'));

  serve(
    content => $src.IO,
    out     => $config.output-dir.IO,
    :$config,
    :$port,
    :$log,
  );
}

multi sub MAIN(
  'clean',
  Str  :$out = 'public',
  Bool :$verbose = False,
  Bool :$quiet = False,
) {
  not-implemented('clean', :$verbose, :$quiet);
}
